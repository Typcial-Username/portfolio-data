{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "repo": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+\\/[a-zA-Z0-9_.-]+$"
        },
        {
          "type": "null"
        }
      ],
      "description": "GitHub repoisitory in the owner/repo format"
    },
    "title": {
      "type": "string",
      "description": "Project title shown on portfolio cards"
    },
    "description": {
      "type": "string"
    },
    "course": {
      "description": "Course this project was created for",
      "type": "string"
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "RES-1",
              "RES-2",
              "RES-3",
              "RES-4",
              "RES-5",
              "RES-6",
              "DMF-1",
              "DMF-2",
              "DMF-3",
              "DMF-4",
              "DMF-5",
              "DMF-6"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "code",
          "reason"
        ],
        "additionalProperties": false
      },
      "description": "The UAT degree objectives this project satisfies"
    },
    "media": {
      "type": "object",
      "properties": {
        "images": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\.(png|jpg|jpeg|webp)$"
          }
        },
        "docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "modelViewer": {
          "type": "string",
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "files": {
      "type": "object",
      "properties": {
        "cad": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\.(f3d|f3z)$"
          }
        },
        "stl": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "\\.stl$"
          }
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": [
        "complete",
        "in-progress",
        "prototype",
        "archived"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "private"
      ]
    }
  },
  "required": [
    "id",
    "title"
  ],
  "additionalProperties": false
}